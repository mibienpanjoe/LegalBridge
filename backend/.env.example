# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/legalbridge

# Embedding provider: "ollama" (local dev) or "huggingface" (production)
EMBEDDING_PROVIDER=ollama

# LLM provider: "ollama" (local dev) or "groq" (production)
LLM_PROVIDER=ollama

# Ollama (used when EMBEDDING_PROVIDER=ollama or LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# HuggingFace Inference API (used when EMBEDDING_PROVIDER=huggingface)
HF_API_KEY=hf_your_token_here

# Groq (used when LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_your_token_here
